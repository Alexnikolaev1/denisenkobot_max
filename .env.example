# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# Токен бота для MAX (в панели бота MAX)
BOT_TOKEN=your_bot_token_here

# URL вашего деплоя на Vercel (нужен только для set-webhook)
# Пример для твоего деплоя (после привязки к Vercel)
VERCEL_URL=https://denisenkobotmax.vercel.app

# Опциональный secret для валидации webhook-запросов MAX
MAX_WEBHOOK_SECRET=your_random_long_secret

# Совместимость с предыдущими версиями проекта (Telegram): можно не задавать
WEBHOOK_SECRET=
